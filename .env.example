SMTP_PASS=hostinger-paskyros-slaptazodis  # Hostinger: email paskyros slaptažodis. Gmail: App Password
EMAIL_FROM=info@klimatovektoriai.lt
EMAIL_MANAGER=brykas@gmail.com        # Kur siųsti lead'us. Gali būti kitas adresas.

